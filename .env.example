# ─── 飞书 Cursor Agent Bridge 配置 ─────────────────
#
# 复制本文件为 .env 并填写实际值
# 或运行 feishu-cursor init 交互式生成配置
#

# 飞书应用凭证（必填，从飞书开放平台获取）
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# cursor-agent 路径（留空自动检测）
# CURSOR_AGENT_PATH=/Users/xxx/.local/bin/cursor-agent

# 默认项目目录（飞书消息不指定路径时使用）
DEFAULT_PROJECT_PATH=/path/to/your/project

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 流式推送间隔（毫秒）
STREAM_PUSH_INTERVAL=3000

# 任务超时时间（毫秒，默认 10 分钟）
TASK_TIMEOUT=600000
